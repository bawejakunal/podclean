# Gemini API Key (get one free at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_api_key_here

# Whisper model to use (tiny, base, small, medium, large-v3)
# large-v3 is highly recommended for accuracy, though slower on older hardware.
WHISPER_MODEL="large-v3"

# Output audio format: mp3, wav, m4a
OUTPUT_FORMAT=mp3

# Output audio bitrate
OUTPUT_BITRATE=192k

# Crossfade duration in milliseconds between cuts
CROSSFADE_MS=300
